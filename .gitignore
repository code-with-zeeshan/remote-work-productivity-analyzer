# ═══════════════════════════════════════════════════════
# ProductivityAnalyzer v2.0 — .gitignore
# ═══════════════════════════════════════════════════════

# ──── Environment & Secrets ────
.env
.env.local
.env.production
.env.*.local

# ──── Python ────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python

# ──── Virtual Environments ────
env/
venv/
.venv/
ENV/

# ──── Distribution / Packaging ────
build/
dist/
*.egg-info/
*.egg
*.whl
*.spec
sdist/
wheels/
*.manifest

# ──── PyInstaller ────
*.exe
*.app

# ──── IDE & Editors ────
.idea/
.vscode/
*.swp
*.swo
*.sln
*.suo
*.ntvs*
*.njsproj
*.pyproj
*.code-workspace
.project
.settings/
*.sublime-project
*.sublime-workspace

# ──── OS Generated ────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ──── Logs ────
logs/
logs/*
*.log
logs/productivity_analyzer.log

# ──── Database (local) ────
*.db
*.sqlite3
*.sqlite

# ──── Exports / Reports (generated) ────
exports/
*.csv
!requirements*.txt

# ──── Coverage & Testing ────
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.pytest_cache/
.tox/
nosetests.xml

# ──── MyPy ────
.mypy_cache/
.dmypy.json
dmypy.json

# ──── Ruff ────
.ruff_cache/

# ──── Docker ────
docker-compose.override.yml

# ──── Misc ────
*.bak
*.tmp
*.temp
*.orig
diagnose.py
verify_final.py
category_rules.json
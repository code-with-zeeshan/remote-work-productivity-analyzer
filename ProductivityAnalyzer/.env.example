# ============================================
# ProductivityAnalyzer Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=remotework

# Connection Pool
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=10

# Application Settings
TRACKING_INTERVAL=5
LOG_RETENTION_DAYS=90
DEBUG=false

# Focus Mode
DEFAULT_FOCUS_DURATION_MINUTES=25
BREAK_REMINDER_MINUTES=45

# Error Tracking (optional — get DSN from sentry.io)
SENTRY_DSN=

# GitHub Integration (optional - for commit analytics)
GITHUB_USERNAME=
GITHUB_TOKEN=

# OpenAI Integration (optional - for AI summaries)
OPENAI_API_KEY=